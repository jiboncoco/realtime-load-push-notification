# Secret untuk docker-compose. Salin ke .env lalu isi (samakan dgn backend/.env).
# .env sudah di-gitignore — JANGAN commit nilai asli.
#
#   cp .env.docker.example .env
#
# VAPID: generate sekali bila belum punya —
#   cd backend && bun -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"

JWT_SECRET=dev-only-change-me
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@demo.test
