# Backend environment (copy to .env and fill)
PORT=3001
# Postgres (matches root docker-compose.yml; host port 55432 → container 5432)
DATABASE_URL=postgres://qms:qms@localhost:55432/qms

# JWT secret untuk sesi CMS (admin/operator). WAJIB diganti di produksi.
JWT_SECRET=dev-only-change-me

# Seed admin awal (dipakai oleh bun run seed)
SEED_CLIENT_NAME=Demo Client
SEED_ADMIN_EMAIL=admin@demo.test
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Demo Admin

# Web Push VAPID (modul Notifications, belum dipakai)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@demo.test
